{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "@emotion/core": "^11.0.0",
    "@emotion/css": "^11.10.0",
    "@emotion/react": "^11.7.1",
    "@emotion/styled": "^11.6.0",
    "@mui/icons-material": "^5.16.7",
    "@mui/material": "^5.16.7",
    "@mui/styled-engine-sc": "^5.14.12",
    "@reach/dialog": "^0.16.2",
    "@testing-library/jest-dom": "^5.16.1",
    "@testing-library/react": "^12.1.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.0.3",
    "@types/node": "^16.11.14",
    "@types/react": "^17.0.37",
    "@types/react-beautiful-dnd": "^13.1.2",
    "@types/react-dom": "^17.0.11",
    "@types/react-router-dom": "^5.3.2",
    "@types/styled-components": "^5.1.18",
    "axios": "^0.24.0",
    "eslint-plugin-jest": "^25.3.0",
    "react": "^17.0.2",
    "react-beautiful-dnd": "^13.1.0",
    "react-dom": "^17.0.2",
    "react-icons": "^4.3.1",
    "react-router-dom": "^6.2.1",
    "react-scripts": "5.0.0",
    "react-toastify": "^9.0.8",
    "styled-components": "^5.3.5",
    "typescript": "^4.5.4",
    "web-vitals": "^2.1.2",
    "ts-jest": "^29.1.0"
  },
  "alias": {
    "@mui/styled-engine": "@mui/styled-engine-sc"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "test": "jest",
    "deploy": "craco build && aws s3 sync ./build s3://todos.jecu.eu --delete && aws cloudfront create-invalidation --distribution-id E3RBZNK0YVAUL3 --paths '/*'",
    "deploy:pages": "PUBLIC_URL=/todos_app craco build && cp build/index.html build/404.html"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "craco-alias": "^3.0.1",
    "jest": "^29.0.1",
    "msw": "^0.45.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{tsx}",
      "!src/**/*.d.ts",
      "!<rootDir>/node_modules/"
    ],
    "moduleNameMapper": {
      "^@assets(.*)$": "<rootDir>/src/assets$1",
      "^@components(.*)$": "<rootDir>/src/components$1",
      "^@constants(.*)$": "<rootDir>/src/constants$1",
      "^@enums(.*)$": "<rootDir>/src/enums$1",
      "^@contexts(.*)$": "<rootDir>/src/contexts$1",
      "^@interfaces(.*)$": "<rootDir>/src/interfaces$1",
      "^@pages(.*)$": "<rootDir>/src/pages$1",
      "^@services(.*)$": "<rootDir>/src/services$1",
      "^@styles(.*)$": "<rootDir>/src/styles$1",
      "^@utils(.*)$": "<rootDir>/src/utils$1",
      "^@test-utils(.*)$": "<rootDir>/src/test-utils$1"
    }
  }
}